# ============================================================
# Videomnix — Environment Variables
# Copiar para .env.local e preencher os valores
# NUNCA commitar .env.local
# ============================================================

# Supabase (projeto exclusivo Videomnix)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# db8-agent — engine compartilhada DB8-Intelligence
DB8_AGENT_URL=https://api.db8intelligence.com.br
DB8_SERVICE_KEY=<valor-de-SERVICE_KEY_CHANNEL-no-Railway>
# X-Service-Key obrigatório em todos os /channel/* endpoints

# YouTube Data API v3
YOUTUBE_CLIENT_ID=<google-cloud-client-id>
YOUTUBE_CLIENT_SECRET=<google-cloud-client-secret>
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/auth/callback

# n8n webhooks
N8N_WEBHOOK_TOKEN=<token-secreto>
N8N_BASE_URL=https://automacao.db8intelligence.com.br

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Videomnix
